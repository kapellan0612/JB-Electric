# Cloudflare Turnstile site key (PUBLIC, embedded in client bundle).
# Vite exposes only variables prefixed with VITE_ to the browser.
# Get from: https://dash.cloudflare.com/?to=/:account/turnstile
VITE_TURNSTILE_SITE_KEY=

# Cloudflare Turnstile secret key (SERVER ONLY, never expose to client).
# Pairs with the site key above.
TURNSTILE_SECRET_KEY=

# Resend API key (SERVER ONLY).
# Get from: https://resend.com/api-keys
RESEND_API_KEY=

# Verified sender address used as the "From" header.
# Must be a verified domain/sender in Resend.
# Example: "JB Electric <quotes@jbelectric.example>"
FROM_EMAIL=

# Address that receives quote-request notifications.
# Example: jhornetbc@gmail.com
NOTIFICATION_EMAIL=
