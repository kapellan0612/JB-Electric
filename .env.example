# Cloudflare Turnstile (get keys at https://dash.cloudflare.com → Turnstile → Add site)
# VITE_ prefix = exposed to browser (required by Vite for client-side env vars)
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# Resend (get API key at https://resend.com/api-keys)
RESEND_API_KEY=re_your_resend_api_key_here

# Sender address — must be on a domain you verified in Resend
FROM_EMAIL=noreply@yourdomain.com

# Where quote-request notifications go
NOTIFICATION_EMAIL=jhornetbc@gmail.com
